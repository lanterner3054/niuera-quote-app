# 自签 HTTPS 反代模板:复制为 Caddyfile 并把 YOUR_SERVER_IP 换成你的服务器公网 IP
# 要加访问密码时,取消 basic_auth 三行注释,哈希用:
#   docker run --rm caddy:2 caddy hash-password --plaintext '你的密码'
# 然后: docker compose restart quote-caddy
{
	# 用 IP 访问时浏览器不发 SNI,必须指定默认证书名,否则 TLS 握手被拒
	default_sni YOUR_SERVER_IP
}

https://YOUR_SERVER_IP:9443, https://127.0.0.1:9443 {
	tls internal
	# basic_auth {
	# 	admin __BASIC_HASH__
	# }
	reverse_proxy quote-app:8000
}
